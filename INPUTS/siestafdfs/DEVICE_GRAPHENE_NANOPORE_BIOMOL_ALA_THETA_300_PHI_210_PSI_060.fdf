###K-Point Mesh###
%block kgrid_Monkhorst_Pack
1   0   0   0.0
0   10   0   0.0
0   0   1   0.0
%endblock kgrid_Monkhorst_Pack


###DEVICE PARAMS###
MeshCutoff          250 Ry
PAO.BasisType       split
PAO.BasisSize       DZP
PAO.EnergyShift     0.1 eV
XC.functional VDW
XC.authors KBM
MaxSCFIterations    2000
SCF.MustConverge    T
DM.MixingWeight     0.01
DM.NumberPulay      20
DM.Tolerance        1.d-5
DM.UseSaveDM        T
ElectronicTemperature 300 K
DirectPhi           T

###DIAGONALIZATION###
SolutionMethod      transiesta

###PARALLELIZATION###
Diag.ParallelOverK  F

###MOLECULAR DYNAMICS###
MD.TypeOfRun        CG
MD.NumCGsteps       0
MD.UseSaveXV        T
MD.UseSaveCG        T


###TS OPTIONS FOLLOW###

# TS.Elecs.Neglect.Principal T

# If this is set to False TranSIESTA dies if there are connections beyond the principal cell.
# If set this to True, non-physical results may arise. Use at your own risk!

TS.Elecs.Eta 10 meV

TS.Voltage 0 eV

%block TS.ChemPots
  Left   # Left Lead
  Right  # Right Lead
%endblock TS.ChemPots

%block TS.ChemPot.Left
  mu V/2
  contour.eq
    begin
      C-Left
      T-Left
    end
%endblock TS.ChemPot.Left

%block TS.ChemPot.Right
  mu -V/2
  contour.eq
    begin
      C-Right
      T-Right
    end
%endblock TS.ChemPot.Right

TS.Contours.Eq.Pole 2.5 eV

%block TS.Contour.C-Left
  part circle
   from -40 eV + V/2 to -10 kT + V/2
     points 25
      method g-legendre
%endblock TS.Contour.C-Left
%block TS.Contour.T-Left
  part tail
   from prev to inf
     points 10
      method g-fermi
%endblock TS.Contour.T-Left

%block TS.Contour.C-Right
  part circle
   from -40 eV -V/2 to -10 kT -V/2
     points 25
      method g-legendre
%endblock TS.Contour.C-Right

%block TS.Contour.T-Right
  part tail
   from prev to inf
     points 10
      method g-fermi
%endblock TS.Contour.T-Right

%block TS.Contours.nEq
  neq
%endblock TS.Contours.nEq

%block TS.Contour.nEq.neq
  part line
   from -|V|/2 - 10 kT to |V|/2 + 10 kT
     delta 0.01 eV
      method mid-rule
%endblock TS.Contour.nEq.neq


###ELECTRODE DEFINITIONS###
%block TS.Elecs
  Left
  Right
%endblock TS.Elecs

%block TS.Elec.Left
  HS ../siesta.TSHS
  chemical-potential Left
  semi-inf-direction -a1
  electrode-position 1
%endblock

%block TS.Elec.Right
  HS ../siesta.TSHS
  chemical-potential Right
  semi-inf-direction +a1
  electrode-position end -1
%endblock


###TBTRANS OPTIONS FOLLOW

TBT.k [1 100 1]
# TBT.T.Eig 100

%block TBT.HS.Files
   ../TS_-0.8/siesta.TSHS -0.8 eV
   ../TS_-0.4/siesta.TSHS -0.4 eV
   ../TS_0.0/siesta.TSHS 0.0 eV
   ../TS_0.4/siesta.TSHS 0.4 eV
   ../TS_0.8/siesta.TSHS 0.8 eV
%endblock

%block TBT.Contours
  IV
%endblock
%block TBT.Contour.IV
   #from -|V|/2 - 10 kT to |V|/2 + 10 kT
   from -2.5 eV to 2.5 eV
     delta 0.01 eV
      method mid-rule
%endblock


###Define which physical quantites to calculate.
# TBT.Emin   -10 eV
# TBT.Emax   +10 eV
# TBT.DOS.Gf true
# TBT.DOS.Elecs true
# TBT.DOS.A true
# TBT.DOS.A.All true
# TBT.T.All true
# TBT.T.Bulk true
# TBT.Current.Orb true

# This FLAG is necessary to obtain the "correct" bond-currents
# TBT.Symmetry.TimeReversal false


###SAVE H and S###
SaveHS  T
SaveElectrostaticPotential  T

